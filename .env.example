# =============================================================================
# GHL MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# These are used by wrangler for local development (wrangler dev).
# For production, set these as Cloudflare Worker secrets (see README.md).
# =============================================================================

# --- Required Secrets (set via: npx wrangler secret put <NAME>) ---

# Admin dashboard password — you choose this, used to log in at /admin
ADMIN_PASSWORD=

# Admin API PIN — you choose this, used in X-Admin-Pin header for API admin routes
ADMIN_PIN=

# GHL OAuth app credentials (from GHL Developer Marketplace)
# If you're only using Private Integration Tokens, set these to any placeholder value
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# --- Optional Secrets ---

# Firebase refresh token for workflow builder tools (BETA)
# GHL_FIREBASE_REFRESH_TOKEN=

# Webhook URL to receive error reports (any webhook endpoint)
# ERROR_WEBHOOK_URL=

# --- Cloudflare Resource IDs (update in wrangler.toml after creating resources) ---

# Worker name — becomes <name>.<subdomain>.workers.dev
# WORKER_NAME=aisimple

# Cloudflare Account ID — found at dash.cloudflare.com, or run: npx wrangler whoami
# CLOUDFLARE_ACCOUNT_ID=

# D1 Database ID — created with: npx wrangler d1 create ghl-accounts
# D1_DATABASE_ID=

# KV Namespace ID — created with: npx wrangler kv namespace create OAUTH_KV
# KV_NAMESPACE_ID=
